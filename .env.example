# =============================================================================
# Docker environment for docker-compose.
# Copy to .env  (cp .env.example .env) and fill the secrets.
# =============================================================================

# ---- Backend: Laravel ----
# Generate with:  docker compose run --rm backend php artisan key:generate --show
APP_KEY=
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DB_DATABASE=baskunana
DB_USERNAME=baskunana
DB_PASSWORD=baskunana

# ---- Sessions (cross-origin: frontend:3000 <-> backend:8000) ----
# In production behind HTTPS, set SESSION_SAME_SITE=none and SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=localhost

# ---- Stripe ----
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---- Frontend: Next.js (build-time, baked into the bundle) ----
# Must be a URL the USER'S BROWSER can reach (not the internal docker hostname)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
